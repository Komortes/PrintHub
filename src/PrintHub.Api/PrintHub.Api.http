@PrintHub.Api_HostAddress = http://localhost:5051
@ApiKey = demo-local-api-key
@jobId = replace-me

GET {{PrintHub.Api_HostAddress}}/health
Accept: application/json

###

GET {{PrintHub.Api_HostAddress}}/settings
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/settings/setup-status
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/settings/auto-start
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

PUT {{PrintHub.Api_HostAddress}}/settings
Content-Type: application/json
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

{
  "serviceName": "PrintHub",
  "port": 5051,
  "bindHost": "127.0.0.1",
  "apiKeyHeaderName": "X-PrintHub-Api-Key",
  "apiKey": "demo-local-api-key",
  "defaultPrinterName": "Office Printer",
  "storageDirectory": "data/documents",
  "maxUploadSizeBytes": 10485760
}

###

PUT {{PrintHub.Api_HostAddress}}/settings/auto-start
Content-Type: application/json
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

{
  "enabled": true
}

###

POST {{PrintHub.Api_HostAddress}}/settings/onboarding
Content-Type: application/json
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

{
  "apiKey": "demo-local-api-key"
}

###

GET {{PrintHub.Api_HostAddress}}/printers
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/printers/diagnostics
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/diagnostics/report
Accept: text/plain
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/diagnostics/support-bundle
Accept: application/zip
Authorization: Bearer {{ApiKey}}

###

PUT {{PrintHub.Api_HostAddress}}/printers/printer_1/default
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/printers/printer_1/test-print
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/print-jobs
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/print-jobs?activeOnly=true&limit=10
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/print-jobs/queue
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/print-jobs/queue/pause
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/print-jobs/queue/resume
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/print-jobs/queue/clear
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/print-jobs
Content-Type: application/json
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

{
  "printerName": "Office Printer",
  "document": {
    "type": "url",
    "url": "https://example.com/file.pdf",
    "data": null,
    "fileName": "file.pdf"
  }
}

###

GET {{PrintHub.Api_HostAddress}}/print-jobs/{{jobId}}
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

GET {{PrintHub.Api_HostAddress}}/print-jobs/{{jobId}}/details
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

DELETE {{PrintHub.Api_HostAddress}}/print-jobs/{{jobId}}
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/print-jobs/{{jobId}}/cancel
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/print-jobs/{{jobId}}/retry
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###

POST {{PrintHub.Api_HostAddress}}/print-jobs/cleanup
Accept: application/json
X-PrintHub-Api-Key: {{ApiKey}}

###
